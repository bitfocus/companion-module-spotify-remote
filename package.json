{
	"name": "spotify-remote",
	"version": "2.6.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw .",
		"lint-fix": "run lint --fix"
	},
	"license": "MIT",
		"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-spotify-remote.git"
	},

	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"./*.{css,json,md,scss}": [
			"prettier --write"
		],
		"!(.squad)/**/*.{css,json,md,scss}": [
			"prettier --write"
		],
		"./*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		],
		"!(.squad)/**/*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"engines": {
		"node": "^22.12",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "~1.14.1",
		"got": "^14.4.7",
		"p-queue": "^8.1.0",
		"type-fest": "^4.39.1"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.6.1",
		"@types/node": "^22.19.3",
		"@types/spotify-api": "^0.0.25",
		"eslint": "^9.39.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"rimraf": "^6.1.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.51.0"
	},
	"packageManager": "yarn@4.9.1"
}
